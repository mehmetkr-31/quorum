{
  "name": "@quorum/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./context": "./src/context.ts",
    "./routers/index": "./src/routers/index.ts"
  },
  "scripts": {
    "dev": "pnpm run indexer",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "indexer": "tsx src/indexer.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^1.33.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@quorum/aptos": "workspace:*",
    "@quorum/auth": "workspace:*",
    "@quorum/db": "workspace:*",
    "@quorum/env": "workspace:*",
    "@quorum/shelby": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "tsx": "^4.21.0",
    "vitest": "^2.0.0",
    "@libsql/client": "catalog:",
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
