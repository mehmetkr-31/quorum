{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@quorum/ui/*": ["../../packages/ui/src/*"],
      "@quorum/api/*": ["../../packages/api/src/*"],
      "@quorum/db/*": ["../../packages/db/src/*"],
      "@quorum/env/*": ["../../packages/env/src/*"],
      "@quorum/aptos/*": ["../../packages/aptos/src/*"],
      "@quorum/shelby/*": ["../../packages/shelby/src/*"]
    }
  }
}
