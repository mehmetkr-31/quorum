# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Production (Turso) — get from: turso db show <db-name> --url
# DATABASE_URL=libsql://<db-name>-<org>.turso.io
# DATABASE_AUTH_TOKEN=<token from: turso db tokens create <db-name>>

# ── Aptos ─────────────────────────────────────────────────────────────────────
APTOS_PRIVATE_KEY=                        # 0x... server signer — same account as SHELBY_ACCOUNT_PRIVATE_KEY on shelbynet
APTOS_API_KEY=
APTOS_NODE_URL=https://api.shelbynet.shelby.xyz/v1
QUORUM_CONTRACT_ADDRESS=0x25b6fd2cd3e4d22c78e680cc125b0ef7bbf298e75c708e9908dc27ade6f4d693

# ── Shelby Protocol ───────────────────────────────────────────────────────────
SHELBY_API_KEY=                                    # Get from geomi.dev
SHELBY_BASE_URL=https://api.shelbynet.shelby.xyz/shelby   # RPC base URL (optional override)
SHELBY_NETWORK=SHELBYNET                           # SHELBYNET | TESTNET | LOCAL
# Aptos account used for Shelby blob uploads on shelbynet.
SHELBY_ACCOUNT_PRIVATE_KEY=                        # 0x... from: aptos config show-private-key --profile quorum-shelby
SHELBY_ACCOUNT_ADDRESS=                            # 0x... account address on shelbynet

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001   # Production: https://yourdomain.com

# ── HuggingFace Hub (optional) ────────────────────────────────────────────────
# Required for dataset.pushToHub endpoint and MCP push_to_huggingface tool.
# Get a Write token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# ── Client-side (Vite prefix required) ───────────────────────────────────────
VITE_CONTRACT_ADDRESS=0x25b6fd2cd3e4d22c78e680cc125b0ef7bbf298e75c708e9908dc27ade6f4d693
VITE_APTOS_NODE_URL=https://api.shelbynet.shelby.xyz/v1
