# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Production (Turso) — get from: turso db show <db-name> --url
# DATABASE_URL=libsql://<db-name>-<org>.turso.io
# DATABASE_AUTH_TOKEN=<token from: turso db tokens create <db-name>>

# ── Aptos ─────────────────────────────────────────────────────────────────────
APTOS_PRIVATE_KEY=
APTOS_API_KEY=
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
QUORUM_CONTRACT_ADDRESS=0x63ff9ee9403ce2bb449294c5f90a6b88b7e56b0e6d8b0d0d5f04a70998d4c7a7

# ── Shelby Protocol ───────────────────────────────────────────────────────────
SHELBY_API_KEY=
SHELBY_BASE_URL=https://api.shelbynet.shelby.xyz/v1
SHELBY_MOCK=true    # Set to false when real Shelby credentials are available

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001   # Production: https://yourdomain.com

# ── Client-side (Vite prefix required) ───────────────────────────────────────
VITE_CONTRACT_ADDRESS=0x63ff9ee9403ce2bb449294c5f90a6b88b7e56b0e6d8b0d0d5f04a70998d4c7a7
VITE_APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
