{
  "buildCommand": "cd ../.. && pnpm --filter @quorum/web build",
  "outputDirectory": "dist/client",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs22.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/_build/:match*",
      "destination": "/_build/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
