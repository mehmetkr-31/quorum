{
  "buildCommand": "cd ../.. && pnpm --filter @quorum/web build",
  "outputDirectory": "dist/client",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/_build/:match*",
      "destination": "/_build/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
