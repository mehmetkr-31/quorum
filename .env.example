# Database
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=             # Turso production token (local'de boş bırakın)

# Aptos
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
APTOS_API_KEY=                   # https://developers.aptoslabs.com → API Key (429'u önler)
APTOS_PRIVATE_KEY=               # Server-side imzalama için (revenue distribute)
QUORUM_CONTRACT_ADDRESS=         # Deploy edilen Move kontrat adresi

# Shelby Protocol
SHELBY_BASE_URL=https://api.shelby.example.com
SHELBY_API_KEY=
SHELBY_MOCK=true                 # Geliştirme için mock — production'da false

# Better Auth
BETTER_AUTH_SECRET=              # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001

# HuggingFace Hub (optional — for dataset.pushToHub)
HUGGINGFACE_TOKEN=               # https://huggingface.co/settings/tokens → Write token
