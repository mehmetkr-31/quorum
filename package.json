{
  "name": "quorum",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --filter @quorum/web",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo -F @quorum/web dev",

    "db:push": "turbo -F @quorum/db db:push",
    "db:studio": "turbo -F @quorum/db db:studio",
    "db:generate": "turbo -F @quorum/db db:generate",
    "db:migrate": "turbo -F @quorum/db db:migrate",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "turbo": "^2.8.12",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
